From cf2d6384bc0a2de737cc47d069e4b9396f277e34 Mon Sep 17 00:00:00 2001
From: Eike Waldt <waldt@b1-systems.de>
Date: Wed, 17 Jun 2026 21:57:00 +0200
Subject: [PATCH] fix 128 players in frontend

Modified for 128 teams support
---
 frontend-qt6/hwconsts.cpp                    | 2 +-
 gameServer/HWProtoInRoomState.hs             | 2 +-
 rust/hedgewars-server/src/handlers/inroom.rs | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/frontend-qt6/hwconsts.cpp b/frontend-qt6/hwconsts.cpp
index 3f3c36051..b1668e8f0 100644
--- a/frontend-qt6/hwconsts.cpp
+++ b/frontend-qt6/hwconsts.cpp
@@ -39,7 +39,7 @@ QDir datadir;
 bool custom_config = false;
 bool custom_data = false;
 
-int cMaxTeams = 8;
+int cMaxTeams = 128;
 int cMaxHHs = HEDGEHOGS_PER_TEAM * cMaxTeams;
 int cMinServerVersion = 3;
 unsigned char cInvertTextColorAt = 64;
diff --git a/gameServer/HWProtoInRoomState.hs b/gameServer/HWProtoInRoomState.hs
index 7689629ed..4f43fa36b 100644
--- a/gameServer/HWProtoInRoomState.hs
+++ b/gameServer/HWProtoInRoomState.hs
@@ -413,7 +413,7 @@ handleCmd_inRoom ["MAXTEAMS", n] = do
     if not $ isMaster cl then
         return [Warning $ loc "You're not the room master!"]
     else if m < 2 || m > cMaxTeams then
-        return [Warning $ loc "/maxteams: specify number from 2 to 8"]
+        return [Warning $ loc "/maxteams: specify number from 2 to 128"]
     else
         return [ModifyRoom (\r -> r{teamsNumberLimit = m})]
 
diff --git a/rust/hedgewars-server/src/handlers/inroom.rs b/rust/hedgewars-server/src/handlers/inroom.rs
index 530e3a6de..6e0caf7f1 100644
--- a/rust/hedgewars-server/src/handlers/inroom.rs
+++ b/rust/hedgewars-server/src/handlers/inroom.rs
@@ -166,7 +166,7 @@ pub fn handle(
                 Ok(()) => {}
                 Err(SetTeamCountError::NotMaster) => response.warn(NOT_MASTER),
                 Err(SetTeamCountError::InvalidNumber) => {
-                    response.warn("/maxteams: specify number from 2 to 8")
+                    response.warn("/maxteams: specify number from 2 to 128")
                 }
             };
         }
